{
  "info": {
    "name": "Banyan API",
    "description": "Complete collection for the Banyan taxonomy platform REST API.\n\nCollection variable `base_url` defaults to http://localhost:8000/api/v1.\n\nThe '00 Happy Path' folder runs top-to-bottom and auto-captures graph_id, node_id_root, node_id_child, and link_id into collection variables via test scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "graph_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "node_id_root",
      "value": "",
      "type": "string"
    },
    {
      "key": "node_id_child",
      "value": "",
      "type": "string"
    },
    {
      "key": "link_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "snapshot_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "00 Happy Path",
      "description": "Run this folder top-to-bottom for an end-to-end walkthrough. IDs are captured automatically.",
      "item": [
        {
          "name": "01 Create Graph",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.collectionVariables.set('graph_id', r.graph_id);",
                  "pm.collectionVariables.set('node_id_root', r.root_node_id);",
                  "pm.test('graph_id captured', () => pm.expect(r.graph_id).to.be.a('string'));",
                  "pm.test('root_node_id auto-set', () => pm.expect(r.root_node_id).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Actor-Id",
                "value": "postman-user"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Product Taxonomy\",\n  \"notes\": \"Top-level product classification hierarchy\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphs",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphs"
              ]
            }
          }
        },
        {
          "name": "02 Add Child Node",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.collectionVariables.set('node_id_child', r.node_id);",
                  "pm.test('child node_id captured', () => pm.expect(r.node_id).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Actor-Id",
                "value": "postman-user"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_id\": \"ELECTRONICS\",\n  \"name\": \"Electronics\",\n  \"notes\": \"Consumer electronics category\",\n  \"metadata\": { \"department_code\": \"EL\" }\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphs/{{graph_id}}/nodes",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphs",
                "{{graph_id}}",
                "nodes"
              ]
            }
          }
        },
        {
          "name": "03 Create HIERARCHICAL Link ($ROOT$ → child)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.collectionVariables.set('link_id', r.link_id);",
                  "pm.test('link_id captured', () => pm.expect(r.link_id).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Actor-Id",
                "value": "postman-user"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"link_type_id\": 1,\n  \"from_graph_id\": \"{{graph_id}}\",\n  \"to_graph_id\": \"{{graph_id}}\",\n  \"from_node_id\": \"{{node_id_root}}\",\n  \"to_node_id\": \"{{node_id_child}}\",\n  \"link_order\": 1.0\n}"
            },
            "url": {
              "raw": "{{base_url}}/links",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "links"
              ]
            }
          }
        },
        {
          "name": "04 Get Subtree",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/graphs/{{graph_id}}/nodes/{{node_id_root}}/subtree",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphs",
                "{{graph_id}}",
                "nodes",
                "{{node_id_root}}",
                "subtree"
              ]
            }
          }
        },
        {
          "name": "05 Get Ancestors of Child",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/graphs/{{graph_id}}/nodes/{{node_id_child}}/ancestors",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphs",
                "{{graph_id}}",
                "nodes",
                "{{node_id_child}}",
                "ancestors"
              ]
            }
          }
        },
        {
          "name": "06 Get Impact Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/graphs/{{graph_id}}/nodes/{{node_id_root}}/impact",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphs",
                "{{graph_id}}",
                "nodes",
                "{{node_id_root}}",
                "impact"
              ]
            }
          }
        },
        {
          "name": "07 Update Node",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Actor-Id",
                "value": "postman-user"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics & Technology\",\n  \"metadata\": { \"department_code\": \"EL\", \"updated\": true }\n}"
            },
            "url": {
              "raw": "{{base_url}}/nodes/{{node_id_child}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "nodes",
                "{{node_id_child}}"
              ]
            }
          }
        },
        {
          "name": "08 Update Link (disable + set valid range)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Actor-Id",
                "value": "postman-user"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"link_order\": 2.0,\n  \"valid_from_datetime\": \"2026-01-01T00:00:00Z\",\n  \"valid_until_datetime\": \"2026-12-31T23:59:59Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/links/{{link_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "links",
                "{{link_id}}"
              ]
            }
          }
        },
        {
          "name": "09 Get Graph History (ledger)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/graphs/{{graph_id}}/history",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphs",
                "{{graph_id}}",
                "history"
              ]
            }
          }
        },
        {
          "name": "10 Create Snapshot",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.collectionVariables.set('snapshot_id', r.snapshot_id);",
                  "pm.test('snapshot_id captured', () => pm.expect(r.snapshot_id).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Actor-Id",
                "value": "postman-user"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"version_label\": \"v1.0-review\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphs/{{graph_id}}/snapshots",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphs",
                "{{graph_id}}",
                "snapshots"
              ]
            }
          }
        },
        {
          "name": "11 Export Graph",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/graphs/{{graph_id}}/export",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphs",
                "{{graph_id}}",
                "export"
              ]
            }
          }
        },
        {
          "name": "12 Diff Graph vs Snapshot",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"base\": \"snapshot:{{snapshot_id}}\",\n  \"compare\": \"{{graph_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphs/diff",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphs",
                "diff"
              ]
            }
          }
        },
        {
          "name": "13 Batch — add node + link in one transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Actor-Id",
                "value": "postman-user"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"graph_id\": \"{{graph_id}}\",\n  \"operations\": [\n    {\n      \"verb\": \"ADD_NODE\",\n      \"data\": {\n        \"source_id\": \"SMARTPHONES\",\n        \"name\": \"Smartphones\",\n        \"notes\": \"Mobile handsets\"\n      }\n    },\n    {\n      \"verb\": \"CREATE_LINK\",\n      \"data\": {\n        \"from_source_id\": \"ELECTRONICS\",\n        \"to_source_id\": \"SMARTPHONES\",\n        \"link_type_id\": 1,\n        \"link_order\": 1.0\n      }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphs/batch",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphs",
                "batch"
              ]
            }
          }
        },
        {
          "name": "14 Restore Snapshot",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.test('new graph_id returned', () => pm.expect(r.graph_id).to.be.a('string'));",
                  "pm.test('name is Restored Graph', () => pm.expect(r.name).to.equal('Restored Graph'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Actor-Id",
                "value": "postman-user"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_name\": \"Restored Graph\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/snapshots/{{snapshot_id}}/restore",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "snapshots",
                "{{snapshot_id}}",
                "restore"
              ]
            }
          }
        }
      ]
    },
